# Local dev: Vite proxies /api -> http://localhost:3001
# Run: npm run dev:all

# Optional production API URL (if API hosted separately)
# Render Static Site + API Web Service: set to your API URL at build time, e.g.:
# VITE_BOOKING_API_URL=https://vip-transfer-api.onrender.com

# Server
PORT=3001
NODE_ENV=development
DATABASE_URL="file:./dev.db"

# JWT (required in production) — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production

# Admin auth (production: use ADMIN_PASSWORD_HASH)
# Generate hash: node -e "import('bcryptjs').then(b=>b.hash('your-password',12).then(console.log))"
# ADMIN_PASSWORD_HASH=$2a$12$...
# ADMIN_PASSWORD=dev-only-plaintext-fallback

# Optional machine-to-machine bearer (scripts/CI)
# ADMIN_API_TOKEN=your-bearer-token

# Notifications (optional webhook for new bookings)
# ADMIN_WEBHOOK_URL=https://hooks.example.com/booking

# Flight tracking (optional). Without a key, the admin panel shows a
# "track on FlightRadar24" link. With a key it shows live status (delay,
# landed, terminal/gate, ETA) via AeroDataBox on RapidAPI.
# Get a key: https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# FLIGHT_API_KEY=your-rapidapi-key
# FLIGHT_API_HOST=aerodatabox.p.rapidapi.com

# CORS (production)
# CORS_ORIGIN=https://viptransfer.com

# Production: use PostgreSQL instead of SQLite
# DATABASE_URL="postgresql://user:pass@host:5432/vip_transfer?schema=public"

# Render (SQLite): set DATABASE_URL=file:./dev.db and Start Command: npm start
# Attach a persistent disk at server/prisma so bookings survive redeploys.
