{
  "name": "viptransfer-com",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run dev:web\"",
    "dev:web": "vite --host",
    "build": "npm run prisma:generate && node --max-old-space-size=4096 node_modules/vite/bin/vite.js build && node scripts/prerender.mjs",
    "build:novsg": "npm run prisma:generate && node --max-old-space-size=4096 node_modules/vite/bin/vite.js build",
    "build:render": "npm run build:novsg",
    "postinstall": "prisma generate --schema=server/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=server/prisma/schema.prisma",
    "start": "npm run prisma:deploy && node server/index.js",
    "render:start": "npm start",
    "prerender": "node scripts/prerender.mjs",
    "build:airports": "node scripts/build-airports.mjs",
    "server": "node server/index.js",
    "prisma:generate": "prisma generate --schema=server/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=server/prisma/schema.prisma",
    "seed": "node server/scripts/seed.mjs",
    "seed:reservations": "node server/scripts/seed-reservations.mjs",
    "rematch-cities": "node server/scripts/rematch-cities.mjs",
    "dev:all": "npm run dev",
    "preview": "vite preview"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "multer": "^2.2.0",
    "prisma": "^6.19.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.15",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^6.0.7"
  }
}
