{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vite-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:web"],
      "port": 5173,
      "autoPort": false
    },
    {
      "name": "vite-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:web", "--", "--port", "5174", "--strictPort"],
      "port": 5174,
      "autoPort": false
    },
    {
      "name": "vite-verify",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:web", "--", "--port", "5188", "--strictPort"],
      "port": 5188,
      "autoPort": false
    },
    {
      "name": "api-server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "server"],
      "port": 3001,
      "autoPort": false
    }
  ]
}
