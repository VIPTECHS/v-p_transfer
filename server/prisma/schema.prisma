generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Booking {
  id                 String   @id @default(cuid())
  reference          String   @unique
  type               String
  status             String   @default("pending")
  pickupAt           DateTime
  fromLabel          String
  toLabel            String?
  durationHours      Int?
  fromLng            Float?
  fromLat            Float?
  toLng              Float?
  toLat              Float?
  firstName          String
  lastName           String?
  email              String
  phone              String
  passengers         Int      @default(1)
  luggage            Int      @default(0)
  childSeat          Int      @default(0)
  vehicle            String?
  notes              String?
  flightNumber       String?
  meetAndGreetName   String?
  returnTransfer     Boolean  @default(false)
  paymentStatus      String   @default("unpaid")
  quotedPrice        Float?
  currency           String   @default("EUR")
  priceNotes         String?
  lastNotifiedAt     DateTime?
  notificationStatus String   @default("none")
  assignedDriverId   String?
  assignedVehicleId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  assignedDriver  Driver?  @relation(fields: [assignedDriverId], references: [id])
  assignedVehicle Vehicle? @relation(fields: [assignedVehicleId], references: [id])
  statusLogs      BookingStatusLog[]
  assignments     BookingAssignment[]

  @@index([pickupAt])
  @@index([status])
  @@index([createdAt])
}

model Enquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Driver {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings    Booking[]
  assignments BookingAssignment[]
}

model Vehicle {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  plate     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings    Booking[]
  assignments BookingAssignment[]
}

model BookingAssignment {
  id         String   @id @default(cuid())
  bookingId  String
  driverId   String?
  vehicleId  String?
  notes      String?
  assignedAt DateTime @default(now())

  booking Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver  Driver?  @relation(fields: [driverId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([bookingId])
}

model BookingStatusLog {
  id         String   @id @default(cuid())
  bookingId  String
  fromStatus String?
  toStatus   String
  note       String?
  createdAt  DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}
